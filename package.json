{
  "name": "agent-lock",
  "version": "0.1.0",
  "description": "File-based CLI tool for AI agent resource coordination using filesystem locks and FIFO queue",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-lock": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "mcp": "node dist/mcp-server.js",
